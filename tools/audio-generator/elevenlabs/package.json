{
  "name": "galaxy-miner-sound-generator",
  "version": "1.0.0",
  "description": "ElevenLabs sound effects generator for Galaxy Miner",
  "main": "generate.js",
  "type": "commonjs",
  "scripts": {
    "generate": "node generate.js",
    "generate:tier1": "node generate.js --tier 1",
    "generate:tier2": "node generate.js --tier 2",
    "generate:weapons": "node generate.js --collection weapons",
    "generate:impacts": "node generate.js --category impacts",
    "generate:destruction": "node generate.js --category destruction",
    "generate:bosses": "node generate.js --category bosses",
    "generate:mining": "node generate.js --category mining",
    "generate:movement": "node generate.js --category movement",
    "generate:ui": "node generate.js --collection ui",
    "generate:weapon-ui": "node generate.js --collection weapon-ui",
    "generate:loot": "node generate.js --category loot",
    "generate:environment": "node generate.js --category environment",
    "generate:rewards": "node generate.js --category rewards",
    "generate:base-destruction": "node generate.js --category base_destruction",
    "list": "node generate.js --list",
    "count": "node generate.js --count",
    "validate": "node generate.js --validate",
    "dry-run:weapon-ui": "node generate.js --dry-run --collection weapon-ui",
    "smoke": "node generate.js --single weapon_t1 --base-only --force --output-dir /tmp/galaxy-miner-elevenlabs-smoke",
    "postprocess:weapon-ui": "node postprocess-assets.js --collection weapon-ui",
    "verify:weapon-ui": "node verify-assets.js --collection weapon-ui",
    "test": "../../../node_modules/.bin/vitest run --root ../../.. tests/unit/tools/elevenlabs-generator.test.js"
  },
  "keywords": [
    "elevenlabs",
    "sound-effects",
    "game-audio",
    "procedural-audio"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Galaxy Miner Team",
  "license": "MIT"
}
